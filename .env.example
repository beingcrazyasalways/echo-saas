# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Mistral AI API Key (for AI chat assistant)
# Get your API key from: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Mistral Document AI API Key (for OCR and document processing)
# Get your API key from: https://console.mistral.ai/
MISTRAL_DOCUMENT_API_KEY=your_mistral_document_api_key_here

# Optional: DeepFace API Key (alternative emotion analysis)
# DEEPFACE_API_KEY=your_deepface_api_key
